# App
APP_NAME=seo-rank-guardian
APP_ENV=development

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8081

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=srg
POSTGRES_PASSWORD=srg_secret
POSTGRES_DB=srg_db
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# NATS
NATS_URL=nats://localhost:4223

# Logger
LOG_LEVEL=debug
LOG_FILE=logs/srg.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=30

# OAuth2
OAUTH_ACCESS_SECRET=your-access-secret-key
OAUTH_REFRESH_SECRET=your-refresh-secret-key
OAUTH_ACCESS_EXPIRY=15m
OAUTH_REFRESH_EXPIRY=168h

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Scraper
SCRAPE_RESULT_LIMIT=10
SCRAPE_MIN_DELAY_MS=2000
SCRAPE_MAX_DELAY_MS=5000
SERPER_API_KEY=
PROXY_URL=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8081/api/v1/auth/google/callback
