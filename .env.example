# App
APP_NAME=seo-rank-guardian
APP_ENV=development

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=srg
POSTGRES_PASSWORD=srg_secret
POSTGRES_DB=srg_db
POSTGRES_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS
NATS_URL=nats://localhost:4222

# Logger
LOG_LEVEL=debug
LOG_FILE=logs/srg.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=30

# OAuth2
OAUTH_ACCESS_SECRET=your-access-secret-key
OAUTH_REFRESH_SECRET=your-refresh-secret-key
OAUTH_ACCESS_EXPIRY=15m
OAUTH_REFRESH_EXPIRY=168h

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# AI
AI_PROVIDER=gemini
AI_API_KEY=your-api-key
AI_MODEL=gemini-2.0-flash
AI_SEARCH_GROUNDING=true

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Scraper
SCRAPE_RESULT_LIMIT=10
SCRAPE_MIN_DELAY_MS=10000
SCRAPE_MAX_DELAY_MS=20000
SCRAPE_MAX_RETRIES=3

# Headless Chrome scraping via Rod (default: true)
SCRAPE_ROD_ENABLED=true
